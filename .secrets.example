# Secrets for local CI testing with act
# Copy to .secrets and fill in values: cp .secrets.example .secrets

# npm registry token (required for release.yml publish-npm job)
NPM_TOKEN=your_npm_token_here

# GitHub PAT with contents:write scope (required for CD auto-tag to trigger release.yml)
# Create at: https://github.com/settings/tokens → Fine-grained → contents:write on this repo
RELEASE_PAT=your_github_pat_here
