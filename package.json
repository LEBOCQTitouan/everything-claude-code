{
  "name": "@lebocqtitouan/ecc",
  "version": "1.0.5",
  "description": "CLI to set up Claude Code configuration — agents, skills, rules, hooks",
  "license": "MIT",
  "main": "./bin/ecc.js",
  "types": "./index.d.ts",
  "bin": {
    "ecc": "./bin/ecc.js"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./bin/ecc.js"
    }
  },
  "files": [
    "bin/",
    "index.d.ts",
    "install.sh",
    "02-examples",
    "03-agents",
    "04-commands",
    "05-skills",
    "06-rules",
    "07-hooks",
    "10-scripts"
  ],
  "scripts": {
    "postinstall": "node 10-scripts/postinstall.js",
    "preuninstall": "node 10-scripts/preuninstall.js",
    "test": "node 11-tests/run-all.js",
    "lint": "markdownlint '**/*.md' --ignore node_modules"
  },
  "dependencies": {
    "omelette": "^0.4.17"
  },
  "devDependencies": {
    "markdownlint-cli": "^0.48.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LEBOCQTitouan/everything-claude-code.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "cli",
    "agents",
    "hooks"
  ]
}
