{
  "name": "@lebocqtitouan/ecc",
  "version": "1.0.6",
  "description": "CLI to set up Claude Code configuration — agents, skills, rules, hooks",
  "license": "MIT",
  "main": "./bin/ecc.js",
  "types": "./index.d.ts",
  "bin": {
    "ecc": "./bin/ecc.js"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./bin/ecc.js"
    }
  },
  "files": [
    "bin/",
    "index.d.ts",
    "install.sh",
    "examples",
    "agents",
    "commands",
    "skills",
    "rules",
    "hooks",
    "contexts",
    "mcp-configs",
    "scripts"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "preuninstall": "node scripts/preuninstall.js",
    "test": "node tests/run-all.js",
    "lint": "markdownlint '**/*.md' --ignore node_modules"
  },
  "dependencies": {
    "omelette": "^0.4.17"
  },
  "devDependencies": {
    "markdownlint-cli": "^0.48.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LEBOCQTitouan/everything-claude-code.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "cli",
    "agents",
    "hooks"
  ]
}
