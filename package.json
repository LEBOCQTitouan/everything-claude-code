{
  "name": "@lebocqtitouan/ecc",
  "version": "1.0.12",
  "description": "CLI to set up Claude Code configuration — agents, skills, rules, hooks",
  "license": "MIT",
  "main": "./bin/ecc.js",
  "types": "./index.d.ts",
  "bin": {
    "ecc": "./bin/ecc.js"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./bin/ecc.js"
    }
  },
  "files": [
    "bin/",
    "index.d.ts",
    "install.sh",
    "examples",
    "agents",
    "commands",
    "skills",
    "rules",
    "hooks",
    "contexts",
    "mcp-configs",
    "dist",
    "scripts/hooks/run-with-flags-shell.sh",
    "scripts/codemaps"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prebuild": "rm -rf dist",
    "postinstall": "node dist/postinstall.js",
    "preuninstall": "node dist/preuninstall.js",
    "test": "npx tsx tests/run-all.js",
    "lint": "markdownlint '**/*.md' --ignore node_modules",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "omelette": "^0.4.17"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "markdownlint-cli": "^0.48.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LEBOCQTitouan/everything-claude-code.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "cli",
    "agents",
    "hooks"
  ]
}
