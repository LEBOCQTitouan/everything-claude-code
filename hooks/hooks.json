{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enableAllProjectMcpServers": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"pre:bash:dev-server-block\" \"standard,strict\""
          }
        ],
        "description": "Block dev servers outside tmux - ensures you can access logs"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"pre:bash:tmux-reminder\" \"strict\""
          }
        ],
        "description": "Reminder to use tmux for long-running commands"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"pre:bash:git-push-reminder\" \"strict\""
          }
        ],
        "description": "Reminder before git push to review changes"
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"pre:write:doc-file-warning\" \"standard,strict\""
          }
        ],
        "description": "Doc file warning: warn about non-standard documentation files (exit code 0; warns only)"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"pre:edit-write:suggest-compact\" \"standard,strict\""
          }
        ],
        "description": "Suggest manual compaction at logical intervals"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"pre:edit:boundary-crossing\" \"standard,strict\""
          }
        ],
        "description": "Block edits that introduce outward imports in domain-layer files"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"pre:edit:stepdown-warning\" \"standard,strict\""
          }
        ],
        "description": "Warn when edit content mixes abstraction levels (Stepdown Rule)"
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"pre:edit-write:workflow-branch-guard\" \"standard,strict\""
          }
        ],
        "description": "Block workflow file edits on protected branches (main/master/production)"
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"pre:compact\" \"standard,strict\""
          }
        ],
        "description": "Save state before context compaction"
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"session:start\" \"minimal,standard,strict\""
          }
        ],
        "description": "Load previous context and detect package manager on new session"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"start:cartography\" \"standard,strict\"",
            "async": true,
            "timeout": 30
          }
        ],
        "description": "Process pending cartography deltas at session start"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"post:bash:pr-created\" \"standard,strict\""
          }
        ],
        "description": "Log PR URL and provide review command after PR creation"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"post:bash:build-complete\" \"standard,strict\"",
            "async": true,
            "timeout": 30
          }
        ],
        "description": "Example: async hook for build analysis (runs in background without blocking)"
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"post:quality-gate\" \"standard,strict\"",
            "async": true,
            "timeout": 30
          }
        ],
        "description": "Run quality gate checks after file edits"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"post:edit:format\" \"standard,strict\""
          }
        ],
        "description": "Auto-format JS/TS files after edits (auto-detects Biome or Prettier)"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"post:edit:typecheck\" \"standard,strict\""
          }
        ],
        "description": "TypeScript check after editing .ts/.tsx files"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"post:edit:console-warn\" \"standard,strict\""
          }
        ],
        "description": "Warn about console.log statements after edits"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"post:edit:boy-scout-delta\" \"standard,strict\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Suggest one small nearby improvement after edits (Boy Scout Rule)"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"post:edit:naming-review\" \"standard,strict\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Flag generic identifier names in edit content"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"post:edit:newspaper-check\" \"standard,strict\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Check public-before-private function ordering after edits"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"post:edit-write:doc-coverage-reminder\" \"standard,strict\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Remind about undocumented exports after source file edits"
      },
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"post:enter-worktree:session-log\" \"standard,strict\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Log worktree creation to active session file"
      },
      {
        "matcher": "ExitWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"post:exit-worktree:cleanup-reminder\" \"standard,strict\""
          }
        ],
        "description": "Remind about unmerged changes after worktree removal"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"stop:notify\" \"minimal,standard,strict\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Send system notification when Claude stops and needs user input"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"stop:uncommitted-reminder\" \"standard,strict\""
          }
        ],
        "description": "Remind about uncommitted changes at session end"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"stop:check-console-log\" \"standard,strict\""
          }
        ],
        "description": "Check for console.log in modified files after each response"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"stop:session-end\" \"minimal,standard,strict\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Persist session state after each response (Stop carries transcript_path)"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"stop:evaluate-session\" \"minimal,standard,strict\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Evaluate session for extractable patterns"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"stop:cost-tracker\" \"minimal,standard,strict\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Track token and cost metrics per session"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"stop:oath-reflection\" \"standard,strict\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Summarize session commits against Programmer's Oath"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"stop:craft-velocity\" \"standard,strict\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Calculate rework ratio and track craft velocity metrics"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"stop:daily-summary\" \"minimal,standard,strict\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Append session summary to daily memory file"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"stop:cartography\" \"minimal,standard,strict\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Write session delta for cartography at session end"
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"post:failure:error-context\" \"standard,strict\""
          }
        ],
        "description": "Suggest recovery commands after tool failures"
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"pre:prompt:context-inject\" \"standard,strict\""
          }
        ],
        "description": "Inject context reminders before prompt processing"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"pre:prompt:context-hydrate\" \"standard,strict\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Pre-hydrate context for ECC commands"
      }
    ],
    "PostCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"post:compact:state-save\" \"standard,strict\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Save compaction summary to session log"
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"subagent:start:log\" \"standard,strict\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Log subagent lifecycle start to session file"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"subagent:start:effort\" \"standard,strict\"",
            "timeout": 5
          }
        ],
        "description": "Set MAX_THINKING_TOKENS based on agent effort field"
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"subagent:stop:log\" \"standard,strict\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Log subagent lifecycle completion to session file"
      }
    ],
    "ConfigChange": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"config:change:log\" \"minimal,standard,strict\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Log configuration changes to session log"
      }
    ],
    "InstructionsLoaded": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"instructions:loaded:validate\" \"standard,strict\""
          }
        ],
        "description": "Validate that instructions file exists and has content"
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"session:end:marker\" \"minimal,standard,strict\""
          }
        ],
        "description": "Session end lifecycle marker (non-blocking)"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-hook \"session:end:worktree-merge\" \"standard,strict\""
          }
        ],
        "description": "Merge worktree back to main at session end (rebase + verify + ff-only)",
        "timeout": 300,
        "async": false
      }
    ]
  }
}
