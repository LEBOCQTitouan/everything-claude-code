{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-workflow phase-gate"
          }
        ],
        "description": "Pipeline: block source writes during spec/design phases"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-workflow tdd-enforcement",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Pipeline: track TDD cycle (informational)"
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-workflow stop-gate"
          }
        ],
        "description": "Pipeline: warn when workflow incomplete"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/doc-enforcement.sh"
          }
        ],
        "description": "Pipeline: warn about missing docs"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pass-condition-check.sh"
          }
        ],
        "description": "Pipeline: warn about pass conditions and E2E #[ignore]"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/e2e-boundary-check.sh"
          }
        ],
        "description": "Pipeline: warn about E2E coverage"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/scope-check.sh"
          }
        ],
        "description": "Pipeline: warn about unexpected file changes (scope creep)"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/doc-level-check.sh"
          }
        ],
        "description": "Pipeline: warn about doc content level violations"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "ecc-workflow grill-me-gate"
          }
        ],
        "description": "Pipeline: warn when grill-me interview not completed in spec output"
      }
    ]
  }
}
